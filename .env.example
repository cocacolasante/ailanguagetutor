# ── Server ───────────────────────────────────────────────────────────────────
PORT=8080

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://fluentica:fluentica@localhost:5432/fluentica?sslmode=disable
POSTGRES_PASSWORD=fluentica

# ── Auth (generate with: openssl rand -hex 32) ────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── IONOS AI Model Hub ────────────────────────────────────────────────────────
# Get your API key from: https://cloud.ionos.com/managed/ai-model-hub
IONOS_API_KEY=your-ionos-api-key

# Available models: mistral-small-24b, meta-llama-3-3-70b, mistral-nemo
IONOS_MODEL=mistral-small-24b
IONOS_BASE_URL=https://openai.inference.de-txl.ionos.com/v1

# ── ElevenLabs ────────────────────────────────────────────────────────────────
# Get your API key from: https://elevenlabs.io
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Conversational AI Agent — create once by calling: POST /api/admin/setup-agent
# (must be authenticated as admin). Paste the returned agent_id here and restart.
ELEVENLABS_AGENT_ID=

# TTS model (used for manual re-play buttons)
ELEVENLABS_MODEL=eleven_multilingual_v2

# Voice IDs per language (find voices at: https://elevenlabs.io/voice-library)
# Defaults to Rachel (multilingual) — replace with native-speaker voices for best results
ELEVENLABS_VOICE_IT=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ES=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_PT=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_FR=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_DE=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_JA=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_RU=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_RO=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ZH=21m00Tcm4TlvDq8ikWAM

# Voice IDs per tutor personality — override with your preferred voices
# Defaults use ElevenLabs pre-made voices that match each personality character
ELEVENLABS_VOICE_PROFESSOR=pNInz6obpgDQGcFmaJgB   # Adam  — deep, authoritative male
ELEVENLABS_VOICE_FRIENDLY=ErXwobaYiN019PkySvjV    # Antoni — warm, conversational male
ELEVENLABS_VOICE_BARTENDER=yoZ06aMxZJJ28mfd3POQ   # Sam   — raspy, casual male
ELEVENLABS_VOICE_EXECUTIVE=TxGEqnHWrfWFTfGW9XjX   # Josh  — confident, professional male
ELEVENLABS_VOICE_TRAVEL=VR6AewLTigWG4xSOukaG      # Arnold — energetic, adventurous male

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get your keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
APP_BASE_URL=https://fluentica.app

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Used to send email verification links to new users.
# Any SMTP provider works (e.g. SendGrid, Postmark, AWS SES, Gmail).
# If SMTP_HOST is left empty, verification emails are skipped and the token
# is logged to stdout — useful for local development.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM=noreply@fluentica.app

# ── Redis ─────────────────────────────────────────────────────────────────────
# REDIS_ADDR is injected automatically as redis:6379 via docker-compose.yml.
# Override only for external Redis (Redis Cloud, ElastiCache, etc.)
# REDIS_ADDR=redis:6379
# REDIS_PASSWORD=
# REDIS_DB=0
# SESSION_TTL=4h
