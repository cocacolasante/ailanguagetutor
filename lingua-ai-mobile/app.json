{
  "expo": {
    "name": "Fluentica AI",
    "slug": "fluentica-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "fluentica",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f1a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fluentica.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Fluentica AI needs microphone access for voice input during language practice sessions."
      }
    },
    "android": {
      "package": "com.fluentica.app",
      "permissions": [
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0f0f1a",
        "foregroundImage": "./assets/adaptive-icon.png"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-av",
        {
          "microphonePermission": "Fluentica AI needs microphone access for voice input during language practice sessions."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1",
          "sounds": []
        }
      ],
      "@stripe/stripe-react-native"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
